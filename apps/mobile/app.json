{
  "expo": {
    "name": "WhoCares",
    "slug": "wedocare-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "wedocare",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.wedocare.app",
      "icon": "./assets/images/app-icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.wedocare.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-android.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "router": {},
      "eas": {
        "projectId": "841f262f-fcbd-458f-93e3-441c3d25970d"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/841f262f-fcbd-458f-93e3-441c3d25970d"
    }
  }
}
