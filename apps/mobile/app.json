{
  "expo": {
    "name": "WhoCares",
    "slug": "wedocare-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "wedocare",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.wedocare.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "co.wedocare.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "apiUrl": "${EXPO_PUBLIC_API_URL}",
      "router": {},
      "eas": {
        "projectId": "841f262f-fcbd-458f-93e3-441c3d25970d"
      }
    }
  }
}
