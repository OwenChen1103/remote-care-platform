{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.wedocare.co"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "whocaresofficial.tw@gmail.com",
        "ascAppId": "6763745600",
        "appleTeamId": "XPP244S2W3"
      }
    }
  }
}
